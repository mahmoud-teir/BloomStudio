# Figma API - Required for design-to-code conversion
# Get your Personal Access Token from: https://www.figma.com/developers/api#access-tokens
FIGMA_PAT=your_figma_personal_access_token_here

# NextAuth - Required for authentication
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database - SQLite (default, no config needed) or change to PostgreSQL/MySQL
# DATABASE_URL="file:./dev.db"

# Optional: OAuth Providers (uncomment and configure as needed)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
